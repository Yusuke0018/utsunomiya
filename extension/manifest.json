{
  "manifest_version": 3,
  "name": "来院理由アンケート集計",
  "version": "1.0.0",
  "description": "デジカル受付一覧から来院理由アンケートを集計します",
  "permissions": ["storage", "activeTab"],
  "host_permissions": ["https://*.supabase.co/*", "https://script.google.com/*"],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "options_page": "options.html",
  "content_scripts": [
    {
      "matches": ["https://digikar.jp/reception/*"],
      "js": ["content.js"],
      "css": ["content.css"]
    }
  ],
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
